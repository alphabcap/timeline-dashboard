# Copy this file to .env and fill in your actual key
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here

# GitHub Gist — shared storage for team members & avatars (all users see same data)
# 1. Go to github.com/settings/tokens → Generate new token (classic) → check "gist" only
# 2. Go to gist.github.com → New gist → filename: magic-team.json → content: [] → Create secret gist
# 3. Copy the Gist ID from the URL (the long string at the end)
VITE_GIST_ID=your_gist_id_here
VITE_GITHUB_TOKEN=ghp_your_token_here
